# Admin secret for generating API keys via the dashboard
# Change this to a strong random string before deploying
ADMIN_SECRET=change-me-before-deploying

# Optional: FCC API User-Agent string
FCC_USER_AGENT=ISPLookupPro/1.0 (contact@yourdomain.com)

# Optional: If FCC requires an API key in the future
# FCC_API_KEY=

# For production: Replace in-memory stores with a real database
# REDIS_URL=redis://...
# DATABASE_URL=postgresql://...
